# ═══════════════════════════════════════
# SWASTIK PRIME — BACKEND ENV TEMPLATE
# Copy this to .env and fill values
# NEVER commit .env to GitHub
# ═══════════════════════════════════════

PORT=3001
NODE_ENV=development

# ── Google Sheets CRM ──────────────────
# Create a service account at console.cloud.google.com
# Share your sheet with the service account email
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Email Notifications (Gmail SMTP) ───
# Use Gmail App Password (not your regular password)
# Enable 2FA → myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=swastikprime@gmail.com
SMTP_PASS=your_16_char_app_password
ADMIN_EMAIL=admin@swastikprime.in

# ── WhatsApp (Twilio) ──────────────────
# Sign up at twilio.com, get sandbox WhatsApp number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ADMIN_WHATSAPP=whatsapp:+91XXXXXXXXXX

# ── Gemini AI ──────────────────────────
# Get key at aistudio.google.com — FREE tier available
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── CORS ───────────────────────────────
FRONTEND_URL=http://localhost:5173
